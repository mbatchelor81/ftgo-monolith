<?xml version="1.0" encoding="UTF-8"?>
<!--
  FTGO Structured Logging Defaults
  Include this file in your service's logback-spring.xml to enable JSON structured logging.
  Usage: <include resource="ftgo-logback-defaults.xml"/>
-->
<included>
    <!-- PII masking converter for sensitive data in log messages -->
    <conversionRule conversionWord="maskedMessage"
        converterClass="com.ftgo.common.logging.masking.PiiMaskingConverter" />

    <!-- Async appender wrapping the JSON console appender for non-blocking logging -->
    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>correlationId</includeMdcKeyName>
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
            <includeMdcKeyName>userId</includeMdcKeyName>
            <includeMdcKeyName>httpMethod</includeMdcKeyName>
            <includeMdcKeyName>requestUri</includeMdcKeyName>
            <includeMdcKeyName>responseStatus</includeMdcKeyName>
            <includeMdcKeyName>durationMs</includeMdcKeyName>
            <fieldNames>
                <timestamp>timestamp</timestamp>
                <version>[ignore]</version>
            </fieldNames>
            <customFields>{"service":"${spring.application.name:-unknown}"}</customFields>
        </encoder>
    </appender>

    <appender name="ASYNC_JSON" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>1024</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="CONSOLE_JSON"/>
    </appender>

    <!-- Standard console appender for local development -->
    <appender name="CONSOLE_PLAIN" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [%X{correlationId:-}] [%X{traceId:-}/%X{spanId:-}] [%X{userId:-}] - %maskedMessage%n</pattern>
        </encoder>
    </appender>
</included>
