# EditorConfig — https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.java]
indent_style = space
indent_size = 2
max_line_length = 120

[*.{gradle,gradle.kts,kts}]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.{xml,xsd}]
indent_style = space
indent_size = 4

[*.{json,json5}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.properties]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
