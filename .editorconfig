# EditorConfig — https://editorconfig.org
# FTGO Project Formatting Standards

root = true

# Default for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Java source files
[*.java]
indent_style = space
indent_size = 4
max_line_length = 120

# Gradle build scripts
[*.gradle]
indent_style = space
indent_size = 4

# Gradle Kotlin DSL
[*.gradle.kts]
indent_style = space
indent_size = 4

# TOML (version catalogs)
[*.toml]
indent_style = space
indent_size = 2

# YAML (CI workflows, Docker Compose, K8s)
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON
[*.json]
indent_style = space
indent_size = 2

# XML (checkstyle, spotbugs, pom, Spring config)
[*.xml]
indent_style = space
indent_size = 4

# Properties files
[*.properties]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2

# Dockerfile
[Dockerfile*]
indent_style = space
indent_size = 4

# Makefiles require tabs
[Makefile]
indent_style = tab
