# =============================================================================
# FTGO EditorConfig — Consistent formatting across all editors and IDEs
# https://editorconfig.org
# =============================================================================

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Java source files
[*.java]
indent_style = space
indent_size = 4
max_line_length = 150

# Gradle build scripts
[*.gradle]
indent_style = space
indent_size = 4

# Gradle Kotlin DSL
[*.gradle.kts]
indent_style = space
indent_size = 4

# Groovy files (buildSrc convention plugins)
[*.groovy]
indent_style = space
indent_size = 4

# XML configuration files
[*.xml]
indent_style = space
indent_size = 4

# YAML files (CI/CD, Docker Compose, Kubernetes)
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

# Properties files
[*.properties]
indent_style = space
indent_size = 4

# Markdown files
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# Shell scripts
[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf

# SQL migration files
[*.sql]
indent_style = space
indent_size = 4

# Dockerfile
[Dockerfile*]
indent_style = space
indent_size = 4
