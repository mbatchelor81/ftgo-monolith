<?xml version="1.0" encoding="UTF-8"?>
<!--
  Shared Logback configuration for all FTGO microservices.
  Provides:
    - Human-readable console output for local development
    - Structured JSON output (via logstash-logback-encoder) for Docker/K8s environments
    - Async appender wrapping JSON output for performance
    - MDC fields: traceId, spanId, correlationId, service, requestMethod, requestUri
-->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="ftgo-service"/>

    <!-- ================================================================== -->
    <!-- Console appender: human-readable format with trace context (local)  -->
    <!-- ================================================================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{traceId:-},%X{spanId:-}] [%X{correlationId:-}] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ================================================================== -->
    <!-- JSON appender: structured logging for EFK stack (Docker/K8s)       -->
    <!-- Uses logstash-logback-encoder for proper JSON escaping and         -->
    <!-- nested field support.                                              -->
    <!-- ================================================================== -->
    <springProfile name="docker | kubernetes">
        <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeCallerData>false</includeCallerData>
                <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSSZ</timestampPattern>
                <!-- Static fields -->
                <customFields>{"service":"${APP_NAME}"}</customFields>
                <!-- Include MDC fields (traceId, spanId, correlationId, etc.) -->
                <includeMdcKeyName>traceId</includeMdcKeyName>
                <includeMdcKeyName>spanId</includeMdcKeyName>
                <includeMdcKeyName>correlationId</includeMdcKeyName>
                <includeMdcKeyName>requestMethod</includeMdcKeyName>
                <includeMdcKeyName>requestUri</includeMdcKeyName>
                <!-- Shorten logger name for readability -->
                <shortenedLoggerNameLength>36</shortenedLoggerNameLength>
            </encoder>
        </appender>

        <!-- Async wrapper for performance — prevents log I/O from blocking request threads -->
        <appender name="ASYNC_JSON" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>1024</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <neverBlock>true</neverBlock>
            <includeCallerData>false</includeCallerData>
            <appender-ref ref="JSON"/>
        </appender>

        <root level="INFO">
            <appender-ref ref="ASYNC_JSON"/>
        </root>
    </springProfile>

    <!-- ================================================================== -->
    <!-- Default console output for local development (no docker/k8s)       -->
    <!-- ================================================================== -->
    <springProfile name="!docker &amp; !kubernetes">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>
</configuration>
