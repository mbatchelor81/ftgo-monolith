<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="ftgo-logback-defaults.xml"/>

    <appender name="CONSOLE_PLAIN" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} [%X{correlationId:-}] [%X{traceId:-}] - %msg%n</pattern>
        </encoder>
    </appender>

    <springProfile name="local">
        <root level="INFO">
            <appender-ref ref="CONSOLE_PLAIN"/>
        </root>
        <logger name="com.ftgo" level="DEBUG"/>
    </springProfile>

    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="ASYNC_CONSOLE_JSON"/>
        </root>
        <logger name="com.ftgo" level="DEBUG"/>
    </springProfile>

    <springProfile name="staging">
        <root level="INFO">
            <appender-ref ref="ASYNC_CONSOLE_JSON"/>
        </root>
        <logger name="com.ftgo" level="INFO"/>
    </springProfile>

    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="ASYNC_CONSOLE_JSON"/>
        </root>
        <logger name="com.ftgo" level="INFO"/>
        <logger name="org.hibernate" level="WARN"/>
        <logger name="org.springframework" level="WARN"/>
    </springProfile>

    <springProfile name="default">
        <root level="INFO">
            <appender-ref ref="ASYNC_CONSOLE_JSON"/>
        </root>
        <logger name="com.ftgo" level="DEBUG"/>
    </springProfile>
</configuration>
