{
  "index_patterns": ["ftgo-logs-*"],
  "template": {
    "settings": {
      "index": {
        "lifecycle": {
          "name": "ftgo-log-retention"
        },
        "number_of_shards": 1,
        "number_of_replicas": 0,
        "refresh_interval": "5s"
      }
    },
    "mappings": {
      "properties": {
        "@timestamp": { "type": "date" },
        "level": { "type": "keyword" },
        "logger_name": { "type": "keyword" },
        "message": { "type": "text" },
        "service": { "type": "keyword" },
        "traceId": { "type": "keyword" },
        "spanId": { "type": "keyword" },
        "correlationId": { "type": "keyword" },
        "thread_name": { "type": "keyword" },
        "requestMethod": { "type": "keyword" },
        "requestUri": { "type": "keyword" },
        "stack_trace": { "type": "text" },
        "kubernetes_namespace": { "type": "keyword" },
        "kubernetes_pod": { "type": "keyword" },
        "kubernetes_container": { "type": "keyword" }
      }
    }
  },
  "priority": 200
}
