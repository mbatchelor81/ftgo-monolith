      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 29},
      "id": 8,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "rate(couriers_registered_total[5m])", "legendFormat": "couriers registered", "refId": "A"},
        {"expr": "rate(couriers_availability_changed_total[5m])", "legendFormat": "availability changes", "refId": "B"},
