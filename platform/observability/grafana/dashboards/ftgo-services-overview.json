      "targets": [
        {"expr": "rate(restaurants_created_total[5m])", "legendFormat": "restaurants created", "refId": "A"},
        {"expr": "rate(restaurants_menu_updated_total[5m])", "legendFormat": "menu updates", "refId": "B"},
        {"expr": "rate(restaurants_orders_accepted_total[5m])", "legendFormat": "orders accepted", "refId": "C"}
      ],
      "title": "Restaurant Activity",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
