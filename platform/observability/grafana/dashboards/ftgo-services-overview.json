      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 21},
      "id": 6,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "rate(consumers_registered_total[5m])", "legendFormat": "consumers registered", "refId": "A"},
        {"expr": "rate(consumers_order_validated_total[5m])", "legendFormat": "order validations OK", "refId": "B"},
        {"expr": "rate(consumers_order_validation_failed_total[5m])", "legendFormat": "order validations FAIL", "refId": "C"}
