<?xml version="1.0" encoding="UTF-8"?>
<!--
  Structured JSON Logback configuration for FTGO platform services.

  Include this in your service's logback-spring.xml:
    <include resource="ftgo/logback-json.xml"/>

  Or use it as your service's logback-spring.xml directly.
-->
<included>
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <timeZone>UTC</timeZone>
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
        </encoder>
    </appender>

    <appender name="PLAIN_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{ISO8601} [%thread] [traceId=%X{traceId} spanId=%X{spanId} correlationId=%X{correlationId}] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!--
      Logstash TCP appender for shipping logs directly to Logstash.
      Activate by including this appender-ref in your service's logback-spring.xml
      and setting ftgo.logging.logstash.destination in application.yml.

      Example:
        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
            <appender-ref ref="LOGSTASH_TCP"/>
        </root>
    -->
    <springProperty scope="context" name="logstashDestination"
                    source="ftgo.logging.logstash.destination"
                    defaultValue="localhost:5000"/>

    <appender name="LOGSTASH_TCP" class="net.logstash.logback.appender.LogstashTcpSocketAppender">
        <destination>${logstashDestination}</destination>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <timeZone>UTC</timeZone>
            <timestampPattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</timestampPattern>
        </encoder>
    </appender>
</included>
