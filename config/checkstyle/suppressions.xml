<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
        "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
        "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
    <!-- Suppress checks for test files -->
    <suppress checks=".*" files=".*Test\.java"/>
    <suppress checks=".*" files=".*Tests\.java"/>
    <suppress checks=".*" files="src[\\/]test[\\/]"/>
    <suppress checks=".*" files="src[\\/]integrationTest[\\/]"/>

    <!-- Suppress HideUtilityClassConstructor for Spring Boot main classes -->
    <suppress checks="HideUtilityClassConstructor" files=".*Application\.java"/>
    <suppress checks="HideUtilityClassConstructor" files=".*Main\.java"/>
</suppressions>
