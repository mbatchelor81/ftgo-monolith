<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!--
        FTGO SpotBugs Exclusion Filter

        Excludes known false positives and patterns that are acceptable
        in the FTGO codebase. Keep exclusions minimal and well-documented.
    -->

    <!-- Exclude Spring-managed classes from serialization warnings -->
    <Match>
        <Bug pattern="SE_NO_SERIALVERSIONID"/>
    </Match>

    <!-- Exclude test classes from all checks -->
    <Match>
        <Source name="~.*Test\.java"/>
    </Match>
    <Match>
        <Source name="~.*Tests\.java"/>
    </Match>
    <Match>
        <Source name="~.*IT\.java"/>
    </Match>

    <!-- Exclude Spring configuration classes from certain checks -->
    <Match>
        <Class name="~.*Configuration"/>
        <Bug pattern="URF_UNREAD_FIELD"/>
    </Match>

    <!-- Exclude DTOs and API models from equals/hashCode warnings -->
    <Match>
        <Package name="~.*\.api\..*"/>
        <Bug pattern="EQ_UNUSUAL"/>
    </Match>

    <!-- Exclude all FTGO packages from mutable-object exposure warnings.
         JPA entities, DTOs, and config classes commonly return/store mutable
         objects; these are false positives in a Spring/JPA codebase. -->
    <Match>
        <Package name="~com\.ftgo\..*"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!-- Exclude JPA domain entities from unread field warnings
         (JPA accesses fields via reflection, so SpotBugs cannot see the reads) -->
    <Match>
        <Package name="com.ftgo.domain"/>
        <Bug pattern="URF_UNREAD_FIELD"/>
    </Match>

    <!-- Exclude test utility library from static exposure warnings.
         PostgresContainerConfig intentionally exposes a shared singleton container. -->
    <Match>
        <Package name="com.ftgo.testlib.containers"/>
        <Bug pattern="MS_EXPOSE_REP"/>
    </Match>

    <!-- Exclude generated code -->
    <Match>
        <Source name="~.*Generated.*\.java"/>
    </Match>

    <!--
        Exclude Spring Boot main classes from static analysis
        (entry points with public static void main)
    -->
    <Match>
        <Class name="~.*Application(Main)?"/>
        <Bug pattern="UMAC_UNCALLABLE_METHOD_OF_ANONYMOUS_CLASS"/>
    </Match>
</FindBugsFilter>
