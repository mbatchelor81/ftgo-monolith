<?xml version="1.0"?>
<ruleset name="FTGO PMD ruleset"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0
                             https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

    <description>
        FTGO PMD ruleset — a curated subset of PMD's built-in categories
        focused on real defects and maintainability concerns rather than
        stylistic preferences. Stylistic enforcement is delegated to
        Checkstyle and Spotless / google-java-format.
    </description>

    <!-- Best practices: point out genuine bugs and API misuse. -->
    <rule ref="category/java/bestpractices.xml">
        <exclude name="JUnitTestsShouldIncludeAssert"/>
        <exclude name="GuardLogStatement"/>
        <exclude name="JUnitAssertionsShouldIncludeMessage"/>
        <exclude name="JUnit4TestShouldUseTestAnnotation"/>
        <exclude name="JUnit4SuitesShouldUseSuiteAnnotation"/>
        <exclude name="JUnit4TestShouldUseAfterAnnotation"/>
        <exclude name="JUnit4TestShouldUseBeforeAnnotation"/>
        <exclude name="JUnitUseExpected"/>
        <exclude name="UseVarargs"/>
        <exclude name="AvoidReassigningParameters"/>
        <exclude name="AccessorClassGeneration"/>
        <exclude name="AccessorMethodGeneration"/>
    </rule>

    <!-- Error-prone: common sources of defects. -->
    <rule ref="category/java/errorprone.xml">
        <exclude name="BeanMembersShouldSerialize"/>
        <exclude name="DataflowAnomalyAnalysis"/>
        <exclude name="MissingSerialVersionUID"/>
        <exclude name="AvoidFieldNameMatchingMethodName"/>
        <exclude name="AvoidFieldNameMatchingTypeName"/>
        <exclude name="AvoidLiteralsInIfCondition"/>
        <exclude name="AvoidDuplicateLiterals"/>
        <exclude name="NullAssignment"/>
        <exclude name="ConstructorCallsOverridableMethod"/>
    </rule>

    <!-- Multithreading: actual concurrency mistakes. -->
    <rule ref="category/java/multithreading.xml">
        <exclude name="UseConcurrentHashMap"/>
        <exclude name="DoNotUseThreads"/>
    </rule>

    <!-- Performance: high-signal performance pitfalls only. -->
    <rule ref="category/java/performance.xml">
        <exclude name="AvoidInstantiatingObjectsInLoops"/>
        <exclude name="RedundantFieldInitializer"/>
    </rule>

    <!-- Security category is small and high-value; include wholesale. -->
    <rule ref="category/java/security.xml"/>

</ruleset>
