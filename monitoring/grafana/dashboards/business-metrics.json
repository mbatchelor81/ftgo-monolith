{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Orders Created (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(ftgo_orders_created_total[5m]) * 60",
          "legendFormat": "orders created"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "opm",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Orders Accepted (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(ftgo_orders_accepted_total[5m]) * 60",
          "legendFormat": "orders accepted"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "opm",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Orders Cancelled vs Delivered",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(ftgo_orders_cancelled_total[5m]) * 60",
          "legendFormat": "cancelled"
        },
        {
          "expr": "rate(ftgo_orders_delivered_total[5m]) * 60",
          "legendFormat": "delivered"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "opm",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Order Totals (cumulative)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "expr": "ftgo_orders_created_total", "legendFormat": "Created" },
        { "expr": "ftgo_orders_accepted_total", "legendFormat": "Accepted" },
        { "expr": "ftgo_orders_delivered_total", "legendFormat": "Delivered" },
        { "expr": "ftgo_orders_cancelled_total", "legendFormat": "Cancelled" },
        { "expr": "ftgo_orders_revised_total", "legendFormat": "Revised" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" }
    },
    {
      "title": "Consumers Registered (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(ftgo_consumers_registered_total[5m]) * 60",
          "legendFormat": "consumers registered"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "opm",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Consumer Validations",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(ftgo_consumers_validations_performed_total[5m]) * 60",
          "legendFormat": "validations performed"
        },
        {
          "expr": "rate(ftgo_consumers_validations_failed_total[5m]) * 60",
          "legendFormat": "validations failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "opm",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Restaurants Created (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(ftgo_restaurants_created_total[5m]) * 60",
          "legendFormat": "restaurants created"
        },
        {
          "expr": "rate(ftgo_restaurants_menu_revisions_total[5m]) * 60",
          "legendFormat": "menu revisions"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "opm",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Couriers Created (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(ftgo_couriers_created_total[5m]) * 60",
          "legendFormat": "couriers created"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "opm",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Courier Deliveries",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(ftgo_couriers_deliveries_assigned_total[5m]) * 60",
          "legendFormat": "assigned"
        },
        {
          "expr": "rate(ftgo_couriers_deliveries_completed_total[5m]) * 60",
          "legendFormat": "completed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "opm",
          "custom": { "drawStyle": "line", "fillOpacity": 20 }
        }
      }
    },
    {
      "title": "Available Couriers",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "ftgo_couriers_available",
          "legendFormat": "available couriers"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "green", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Order Processing Time (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(ftgo_orders_processing_time_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(ftgo_orders_processing_time_seconds_bucket[5m]))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["ftgo", "business-metrics", "observability"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "FTGO — Business Metrics",
  "uid": "ftgo-business-metrics"
}
