      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Order Service Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "fillOpacity": 20, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" } },
      "title": "Order Lifecycle Rates",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(ftgo_orders_created_total[5m])",
          "legendFormat": "Created"
        },
        {
          "expr": "rate(ftgo_orders_accepted_total[5m])",
          "legendFormat": "Accepted"
        },
        {
          "expr": "rate(ftgo_orders_delivered_total[5m])",
          "legendFormat": "Delivered"
        },
        {
          "expr": "rate(ftgo_orders_cancelled_total[5m])",
          "legendFormat": "Cancelled"
        },
        {
          "expr": "rate(ftgo_orders_revised_total[5m])",
          "legendFormat": "Revised"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "blue", "value": 10 },
              { "color": "yellow", "value": 100 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "textMode": "auto" },
      "title": "Active Orders",
      "type": "stat",
      "targets": [
        {
          "expr": "ftgo_orders_active",
          "legendFormat": "Active Orders"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
