        {
          "expr": "ftgo_orders_processing_duration_seconds{quantile=\"0.95\"}",
          "legendFormat": "p95"
        },
        {
          "expr": "ftgo_orders_processing_duration_seconds{quantile=\"0.99\"}",
          "legendFormat": "p99"
        }
