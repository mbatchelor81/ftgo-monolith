{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "JVM Memory",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "fillOpacity": 20, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" } },
      "title": "Heap Memory Used vs Max",
      "type": "timeseries",
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=~\"$service\", area=\"heap\"}",
          "legendFormat": "{{ job }} — used"
        },
        {
          "expr": "jvm_memory_max_bytes{job=~\"$service\", area=\"heap\"}",
          "legendFormat": "{{ job }} — max"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "fillOpacity": 20, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" } },
      "title": "Non-Heap Memory Used",
      "type": "timeseries",
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=~\"$service\", area=\"nonheap\"}",
          "legendFormat": "{{ job }} — {{ id }}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          },
          "unit": "percentunit",
          "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 9 },
      "id": 3,
      "options": { "orientation": "horizontal", "showThresholdLabels": false, "showThresholdMarkers": true },
      "title": "Heap Usage %",
      "type": "gauge",
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=~\"$service\", area=\"heap\"} / jvm_memory_max_bytes{job=~\"$service\", area=\"heap\"}",
          "legendFormat": "{{ job }}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 101,
      "title": "Garbage Collection",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "fillOpacity": 20, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 4,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" } },
      "title": "GC Pause Duration",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{job=~\"$service\"}[5m])",
          "legendFormat": "{{ job }} — {{ action }} ({{ cause }})"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "fillOpacity": 20, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 5,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" } },
      "title": "GC Collection Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_count{job=~\"$service\"}[5m])",
          "legendFormat": "{{ job }} — {{ action }}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 102,
      "title": "Threads & CPU",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "fillOpacity": 20, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "id": 6,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" } },
      "title": "Live Threads",
      "type": "timeseries",
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=~\"$service\"}",
          "legendFormat": "{{ job }} — live"
        },
        {
          "expr": "jvm_threads_daemon_threads{job=~\"$service\"}",
          "legendFormat": "{{ job }} — daemon"
        },
        {
          "expr": "jvm_threads_peak_threads{job=~\"$service\"}",
          "legendFormat": "{{ job }} — peak"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "fillOpacity": 20, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "id": 7,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" } },
      "title": "Process CPU Usage",
      "type": "timeseries",
      "targets": [
        {
          "expr": "process_cpu_usage{job=~\"$service\"}",
          "legendFormat": "{{ job }} — process"
        },
        {
          "expr": "system_cpu_usage{job=~\"$service\"}",
          "legendFormat": "{{ job }} — system"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 103,
      "title": "Connection Pools",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "fillOpacity": 20, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "id": 8,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" } },
      "title": "HikariCP Active Connections",
      "type": "timeseries",
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=~\"$service\"}",
          "legendFormat": "{{ job }} — active"
        },
        {
          "expr": "hikaricp_connections_idle{job=~\"$service\"}",
          "legendFormat": "{{ job }} — idle"
        },
        {
          "expr": "hikaricp_connections_max{job=~\"$service\"}",
          "legendFormat": "{{ job }} — max"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "fillOpacity": 20, "lineWidth": 2, "showPoints": "never", "spanNulls": true },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "id": 9,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" } },
      "title": "HikariCP Connection Acquire Time",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(hikaricp_connections_acquire_seconds_sum{job=~\"$service\"}[5m]) / rate(hikaricp_connections_acquire_seconds_count{job=~\"$service\"}[5m])",
          "legendFormat": "{{ job }}"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["ftgo", "jvm", "spring-boot"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(jvm_memory_used_bytes, job)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "service",
        "query": "label_values(jvm_memory_used_bytes, job)",
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "FTGO — JVM Metrics",
  "uid": "ftgo-jvm-metrics",
  "version": 1
}
